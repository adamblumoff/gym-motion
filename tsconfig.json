{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "@core/*": ["shared/*"],
      "@main/*": ["desktop/main/*"],
      "@ui/*": ["desktop/ui/src/*"]
    }
  },
  "include": [
    "backend/**/*.d.ts",
    "backend/**/*.ts",
    "shared/**/*.ts",
    "desktop/**/*.ts",
    "desktop/**/*.tsx",
    "electron.vite.config.ts",
    "vitest.config.ts",
    "vitest.db.config.ts"
  ],
  "exclude": [
    "backend/**/*.db.test.ts",
    "backend/**/*.test.ts",
    "backend/runtime/**/*.ts",
    "desktop/e2e/fake-gateway-child.ts",
    "desktop/**/*.test.ts",
    "desktop/scripts/windows-winrt-gateway*.ts",
    "desktop/**/*.test-helpers.ts",
    "shared/**/*.test.ts"
  ]
}
