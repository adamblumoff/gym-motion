{
  "name": "gym-motion-legacy",
  "version": "0.1.0",
  "private": true,
  "description": "Gateway-first motion dashboard for BLE sensor nodes with an ESP32 reference node implementation.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "bun test",
    "db:setup": "bun run ./scripts/setup-db.ts",
    "db:migrate:timestamps": "bun run ./scripts/migrate-timestamps.ts",
    "seed": "bun run ./scripts/send-test-event.ts",
    "gateway": "node ./scripts/ble-gateway.mjs",
    "firmware:build": "./scripts/build-firmware.sh",
    "firmware:sync:windows": "./scripts/sync-windows-firmware.sh",
    "firmware:upload": "./scripts/upload-firmware.sh",
    "firmware:publish": "bun run ./scripts/publish-firmware.ts",
    "reference-node:build": "./scripts/build-firmware.sh",
    "reference-node:upload": "./scripts/upload-firmware.sh",
    "reference-node:publish": "bun run ./scripts/publish-firmware.ts",
    "device:purge": "bun run ./scripts/purge-device.ts"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-26",
    "@aws-sdk/client-s3": "^3.1003.0",
    "@aws-sdk/s3-request-presigner": "^3.1003.0",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@abandonware/bluetooth-hci-socket",
    "@abandonware/noble",
    "sharp",
    "unrs-resolver"
  ]
}
