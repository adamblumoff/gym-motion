{
  "name": "gym-motion-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Windows-first Gym Motion desktop gateway and operator console.",
  "main": "out/main/index.js",
  "author": "Gym Motion",
  "scripts": {
    "db:setup": "bun run ./scripts/setup-db.ts",
    "db:migrate:timestamps": "bun run ./scripts/migrate-timestamps.ts",
    "db:rebuild:motion-rollups": "bun run ./scripts/rebuild-motion-rollups.ts",
    "worktree:create:t3": "bun run ./scripts/create-t3-worktree.ts",
    "build:runtime": "tsc -p tsconfig.runtime.json",
    "dev": "bun run build:runtime && bun run scripts/build-windows-ble-sidecar.mjs && electron-vite dev",
    "build:desktop:test": "bun run build:runtime && bun run scripts/build-windows-ble-sidecar.mjs && electron-vite build",
    "build": "bun run build:runtime && electron-vite build && electron-builder --config electron-builder.config.mjs --dir",
    "build:win": "bun run build:runtime && bun run scripts/build-windows-ble-sidecar.mjs && electron-vite build && electron-builder --config electron-builder.config.mjs --win nsis portable",
    "preview": "electron-vite preview",
    "seed": "bun run ./scripts/send-test-event.ts",
    "firmware:build": "bash ./scripts/build-firmware.sh",
    "firmware:test:host": "python ./scripts/test-firmware-host.py",
    "firmware:upload": "bash ./scripts/upload-firmware.sh",
    "firmware:publish": "bun run ./scripts/publish-firmware.ts",
    "device:purge": "bun run ./scripts/purge-device.ts",
    "lint": "eslint \"backend/**/*.ts\" \"desktop/**/*.ts\" \"desktop/**/*.tsx\" \"shared/**/*.ts\" \"scripts/**/*.ts\" \"*.config.ts\"",
    "test:boundaries": "node ./scripts/check-no-archive-imports.mjs && node ./scripts/check-file-sizes.mjs && node ./scripts/check-no-legacy-desktop-imports.mjs",
    "test:ts": "vitest run --config vitest.config.ts",
    "test:backend:db": "vitest run --config vitest.db.config.ts",
    "test": "bun run test:boundaries && bun run test:ts",
    "test:e2e:desktop": "bun run build:desktop:test && playwright test -c playwright.desktop.config.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.runtime.json",
    "smoke:windows-desktop": "./scripts/test-windows-desktop.sh",
    "test:windows-desktop": "bun run test:e2e:desktop"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1003.0",
    "@aws-sdk/s3-request-presigner": "^3.1003.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^16.6.1",
    "lucide-react": "^0.577.0",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.13.1",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@eslint/js": "^9.23.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^36.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "eslint": "^9.35.0",
    "globals": "^16.3.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vitest": "^3.2.4"
  }
}
