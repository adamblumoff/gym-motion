{
  "name": "gym-motion-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Windows-first Gym Motion desktop gateway and operator console.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder --dir",
    "build:win": "electron-vite build && electron-builder --win nsis portable",
    "preview": "electron-vite preview",
    "lint": "eslint desktop --ext .ts,.tsx",
    "test": "bun test desktop",
    "typecheck": "tsc --noEmit",
    "legacy:dev": "cd legacy && bun dev",
    "test:windows-desktop": "./scripts/test-windows-desktop.sh"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-26",
    "@aws-sdk/client-s3": "^3.1003.0",
    "@aws-sdk/s3-request-presigner": "^3.1003.0",
    "dotenv": "^16.6.1",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^36.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "eslint": "^9.35.0",
    "globals": "^16.3.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0"
  },
  "build": {
    "appId": "com.gymmotion.desktop",
    "productName": "Gym Motion",
    "asar": true,
    "asarUnpack": [
      "legacy/scripts/**"
    ],
    "files": [
      "dist/**",
      "out/**",
      "legacy/scripts/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
