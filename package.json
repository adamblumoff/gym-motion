{
  "name": "gym-motion-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Windows-first Gym Motion desktop gateway and operator console.",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "bun run scripts/build-windows-ble-sidecar.mjs && electron-vite dev",
    "build": "electron-vite build && electron-builder --config electron-builder.config.mjs --dir",
    "build:win": "bun run scripts/build-windows-ble-sidecar.mjs && electron-vite build && electron-builder --config electron-builder.config.mjs --win nsis portable",
    "preview": "electron-vite preview",
    "lint": "eslint desktop --ext .ts,.tsx",
    "test:boundaries": "node ./scripts/check-no-legacy-imports.mjs",
    "test": "bun run test:boundaries && bun test ./desktop/main ./desktop/core ./desktop/ui ./desktop/scripts",
    "typecheck": "tsc --noEmit",
    "legacy:dev": "cd legacy && bun dev",
    "test:windows-desktop": "./scripts/test-windows-desktop.sh"
  },
  "dependencies": {
    "@abandonware/noble": "^1.9.2-26",
    "@aws-sdk/client-s3": "^3.1003.0",
    "@aws-sdk/s3-request-presigner": "^3.1003.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^16.6.1",
    "lucide-react": "^0.577.0",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.13.1",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^36.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "eslint": "^9.35.0",
    "globals": "^16.3.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0"
  }
}
