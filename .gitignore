# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/firmware/build
/firmware/.pio/
/firmware/.vscode/
/dist
/release
/bin/arduino-cli
/playwright-results/
/firmware/.gitignore

# misc
.DS_Store
*.pem
/data/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.tmp-dev*.log
.tmp-sidecar-run.log

# env files (can opt-in for committing if needed)
.env*
.env.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# rust
target/

# dotnet native helpers
native/**/bin/
native/**/obj/
gym-motion.sln
scripts/linux-gateway/linux-ble-gateway.env
scripts/linux-gateway/linux-ble-gateway.nodes.json
